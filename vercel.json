{
	"headers": [
		{
			"source": "/(.*)\\.(woff2|ttf)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(logos|home-server|og)/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		}
	]
}
